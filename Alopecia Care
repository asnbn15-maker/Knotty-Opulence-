<style>
  :root {
    --cream: #F5F0E8;
    --deep-brown: #2C1810;
    --warm-brown: #3D2B1F;
    --gold: #D4A853;
    --sage: #6B7C5C;
    --mist: #E8E0D0;
    --white: #FDFAF5;
    --text-muted: #7A6455;
    --dusty-rose: #C4A090;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--cream); color: var(--deep-brown); font-family: 'Jost', sans-serif; font-weight: 300; overflow-x: hidden; }

  /* NAV */
  nav { position: fixed; top: 0; width: 100%; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 1rem 3rem; background: rgba(245,240,232,0.97); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(212,168,83,0.2); min-height: 60px; }
  .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; color: var(--warm-brown); text-decoration: none; white-space: nowrap; }
  .nav-logo em { color: var(--gold); font-style: italic; }
  .nav-links { display: flex; gap: 2rem; list-style: none; align-items: center; }
  .nav-links a { text-decoration: none; color: var(--warm-brown); font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; transition: color 0.3s; }
  .nav-links a:hover, .nav-links a.active { color: var(--gold); }
  .nav-book { background: var(--deep-brown); color: var(--cream); padding: 0.6rem 1.4rem; text-decoration: none; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; transition: background 0.3s; white-space: nowrap; }
  .nav-book:hover { background: var(--gold); color: var(--deep-brown); }
  .nav-mobile-btn { display: none; background: none; border: none; color: var(--warm-brown); font-size: 1.6rem; cursor: pointer; padding: 0.2rem 0.4rem; line-height: 1; }
  .nav-has-dropdown { position: relative; }
  .nav-has-dropdown > a::after { content: ' ▾'; font-size: 0.55rem; opacity: 0.6; vertical-align: middle; }
  .nav-dropdown { display: none; position: absolute; top: calc(100% + 12px); left: 50%; transform: translateX(-50%); background: var(--deep-brown); border: 1px solid rgba(212,168,83,0.2); border-top: 2px solid var(--gold); min-width: 210px; box-shadow: 0 20px 40px rgba(0,0,0,0.3); z-index: 300; }
  .nav-has-dropdown:hover .nav-dropdown { display: block; }
  .nav-dropdown a { display: block; padding: 0.85rem 1.4rem; text-decoration: none; color: rgba(245,240,232,0.65); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; border-bottom: 1px solid rgba(212,168,83,0.08); transition: all 0.2s; }
  .nav-dropdown a:last-child { border-bottom: none; }
  .nav-dropdown a:hover { color: var(--cream); background: rgba(212,168,83,0.08); padding-left: 1.8rem; }
  .nav-dropdown a.coming-soon { opacity: 0.45; cursor: default; pointer-events: none; }
  .nav-dropdown a.coming-soon::after { content: ' — soon'; font-size: 0.6rem; }

  /* MOBILE DRAWER */
  .mobile-drawer { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 200; }
  .mobile-drawer.open { display: block; }
  .mobile-drawer-overlay { position: absolute; inset: 0; background: rgba(26,10,5,0.7); }
  .mobile-drawer-panel { position: absolute; top: 0; right: 0; width: 78%; max-width: 320px; height: 100%; background: var(--deep-brown); border-left: 1px solid rgba(212,168,83,0.2); padding: 5rem 2.5rem 3rem; display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.4,0,0.2,1); }
  .mobile-drawer.open .mobile-drawer-panel { transform: translateX(0); }
  .mobile-drawer-close { position: absolute; top: 1.2rem; right: 1.5rem; background: none; border: none; color: var(--cream); font-size: 1.5rem; cursor: pointer; opacity: 0.7; }
  .mobile-drawer-links { list-style: none; display: flex; flex-direction: column; }
  .mobile-drawer-links li { border-bottom: 1px solid rgba(212,168,83,0.12); }
  .mobile-drawer-links a { display: block; padding: 1.1rem 0; text-decoration: none; color: rgba(245,240,232,0.75); font-size: 0.85rem; letter-spacing: 0.14em; text-transform: uppercase; transition: color 0.2s; }
  .mobile-drawer-links a:hover { color: var(--gold); }
  .mobile-drawer-book { display: block; margin-top: 2.5rem; background: var(--warm-brown); color: var(--cream); padding: 1rem; text-align: center; text-decoration: none; font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase; transition: background 0.25s; }
  .mobile-drawer-book:hover { background: var(--gold); color: var(--deep-brown); }
  .drawer-has-sub { border-bottom: 1px solid rgba(212,168,83,0.12); }
  .drawer-parent-btn { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 1.1rem 0; background: none; border: none; cursor: pointer; color: rgba(245,240,232,0.75); font-family: 'Jost', sans-serif; font-size: 0.85rem; letter-spacing: 0.14em; text-transform: uppercase; transition: color 0.2s; }
  .drawer-parent-btn:hover { color: var(--gold); }
  .drawer-chevron { font-size: 0.7rem; transition: transform 0.3s; display: inline-block; }
  .drawer-parent-btn[aria-expanded="true"] .drawer-chevron { transform: rotate(180deg); }
  .drawer-submenu { list-style: none; max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
  .drawer-submenu.open { max-height: 400px; }
  .drawer-submenu li { border-top: 1px solid rgba(212,168,83,0.07); }
  .drawer-submenu a { display: block; padding: 0.85rem 0 0.85rem 1.2rem; text-decoration: none; color: rgba(245,240,232,0.55); font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; transition: color 0.2s; }
  .drawer-submenu a:hover { color: var(--cream); }

  /* HERO */
  .hero {
    min-height: 100vh;
    background: linear-gradient(160deg, #1C1018 0%, #2C1820 50%, #3A2030 100%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 0 6rem 6rem; position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 85% 25%, rgba(196,160,144,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 15% 75%, rgba(107,124,92,0.06) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero-ornament {
    position: absolute; top: 4rem; right: 4rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 22vw; font-weight: 300; line-height: 1;
    color: rgba(196,160,144,0.05); pointer-events: none; user-select: none;
    letter-spacing: -0.04em;
  }
  .hero-content { position: relative; z-index: 1; max-width: 820px; }
  .hero-label { font-size: 0.68rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(196,160,144,0.7); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1rem; animation: fadeUp 0.9s ease 0.2s both; }
  .hero-label::before { content: ''; width: 36px; height: 1px; background: var(--dusty-rose); }
  .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(3.5rem, 8vw, 9rem); font-weight: 300; line-height: 0.95; color: var(--cream); letter-spacing: -0.02em; margin-bottom: 2rem; animation: fadeUp 0.9s ease 0.35s both; }
  .hero h1 em { color: var(--dusty-rose); font-style: italic; }
  .hero-sub { font-size: clamp(0.95rem, 1.4vw, 1.15rem); line-height: 1.85; color: rgba(245,240,232,0.5); max-width: 560px; margin-bottom: 3rem; animation: fadeUp 0.9s ease 0.5s both; }
  .hero-cta { animation: fadeUp 0.9s ease 0.65s both; }
  .btn-rose { background: var(--dusty-rose); color: var(--deep-brown); border: none; padding: 1rem 2.4rem; text-decoration: none; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 500; transition: background 0.3s; display: inline-block; }
  .btn-rose:hover { background: var(--cream); }
  .hero-note { margin-top: 1.5rem; font-size: 0.78rem; color: rgba(245,240,232,0.3); letter-spacing: 0.05em; font-style: italic; animation: fadeUp 0.9s ease 0.8s both; }

  /* UNDERSTANDING SECTION */
  .understand-section { padding: 7rem 6rem; background: var(--white); display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
  .eyebrow { font-size: 0.68rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
  .section-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem,3.5vw,3.8rem); font-weight: 300; color: var(--warm-brown); line-height: 1.1; margin-bottom: 2rem; }
  .section-title em { color: var(--dusty-rose); font-style: italic; }
  .rule { width: 48px; height: 1px; background: var(--dusty-rose); margin-bottom: 2rem; }
  .body-text { font-size: 0.95rem; line-height: 1.9; color: var(--text-muted); margin-bottom: 1.5rem; }
  .understand-quote { border-left: 3px solid var(--dusty-rose); padding: 2rem 2.5rem; background: rgba(196,160,144,0.06); }
  .understand-quote-text { font-family: 'Cormorant Garamond', serif; font-size: 1.55rem; font-weight: 300; color: var(--warm-brown); line-height: 1.45; font-style: italic; margin-bottom: 1.2rem; }
  .understand-quote-attr { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); }

  /* WHAT YOU ARE FACING */
  .facing-section { background: var(--deep-brown); padding: 7rem 6rem; }
  .facing-header { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; margin-bottom: 5rem; }
  .facing-eyebrow { font-size: 0.68rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(196,160,144,0.6); margin-bottom: 1rem; }
  .facing-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,3.5vw,3.5rem); font-weight: 300; color: var(--cream); line-height: 1.1; }
  .facing-title em { color: var(--dusty-rose); font-style: italic; }
  .facing-rule { width: 48px; height: 1px; background: var(--dusty-rose); margin: 1.5rem 0; }
  .facing-body { font-size: 0.92rem; line-height: 1.9; color: rgba(245,240,232,0.5); }
  .facing-cards { display: grid; grid-template-columns: repeat(2,1fr); gap: 1.5px; }
  .facing-card { background: rgba(245,240,232,0.04); border: 1px solid rgba(196,160,144,0.12); padding: 2.5rem 2rem; transition: border-color 0.3s; }
  .facing-card:hover { border-color: rgba(196,160,144,0.35); }
  .facing-card-icon { font-size: 1.8rem; margin-bottom: 1.2rem; }
  .facing-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--cream); margin-bottom: 0.6rem; }
  .facing-card-body { font-size: 0.82rem; line-height: 1.75; color: rgba(245,240,232,0.45); }

  /* THE APPROACH */
  .approach-section { padding: 7rem 6rem; background: var(--cream); }
  .approach-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
  .approach-steps { display: flex; flex-direction: column; gap: 1.5px; }
  .approach-step { background: var(--white); padding: 2rem 2rem; border-left: 3px solid transparent; transition: border-color 0.3s; }
  .approach-step:hover { border-color: var(--dusty-rose); }
  .approach-step-num { font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; color: rgba(196,160,144,0.5); letter-spacing: 0.1em; margin-bottom: 0.4rem; }
  .approach-step-title { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; color: var(--warm-brown); margin-bottom: 0.5rem; }
  .approach-step-body { font-size: 0.82rem; line-height: 1.7; color: var(--text-muted); }

  /* WHAT TO EXPECT */
  .expect-section { background: linear-gradient(135deg, var(--warm-brown) 0%, var(--deep-brown) 100%); padding: 6rem 6rem; }
  .expect-header { text-align: center; margin-bottom: 4rem; }
  .expect-eyebrow { font-size: 0.68rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(196,160,144,0.6); margin-bottom: 1rem; }
  .expect-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,3.5vw,3.2rem); font-weight: 300; color: var(--cream); line-height: 1.1; }
  .expect-title em { color: var(--dusty-rose); font-style: italic; }
  .expect-rule { width: 48px; height: 1px; background: var(--dusty-rose); margin: 1.2rem auto 0; }
  .expect-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5px; }
  .expect-card { background: rgba(245,240,232,0.05); border: 1px solid rgba(196,160,144,0.12); padding: 2.5rem 2rem; }
  .expect-card-num { font-family: 'Cormorant Garamond', serif; font-size: 3rem; color: rgba(196,160,144,0.2); line-height: 1; margin-bottom: 1rem; }
  .expect-card-title { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; color: var(--cream); margin-bottom: 0.6rem; }
  .expect-card-body { font-size: 0.82rem; line-height: 1.75; color: rgba(245,240,232,0.45); }

  /* IMPORTANT NOTE */
  .note-strip { background: rgba(196,160,144,0.1); border-top: 1px solid rgba(196,160,144,0.2); border-bottom: 1px solid rgba(196,160,144,0.2); padding: 2rem 6rem; display: flex; align-items: flex-start; gap: 1.5rem; }
  .note-strip-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem; }
  .note-strip-text { font-size: 0.85rem; line-height: 1.75; color: rgba(245,240,232,0.55); }
  .note-strip-text strong { color: rgba(245,240,232,0.8); font-weight: 500; }

  /* CONSULT CTA */
  .consult-section { padding: 7rem 6rem; background: var(--white); display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .consult-left { background: linear-gradient(160deg, #2C1820 0%, #1C1018 100%); padding: 5rem 4rem; display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden; }
  .consult-left::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 60% at 80% 20%, rgba(196,160,144,0.1) 0%, transparent 60%); pointer-events: none; }
  .consult-left-label { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(196,160,144,0.6); margin-bottom: 0.8rem; position: relative; z-index: 1; }
  .consult-left-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem,3vw,3rem); font-weight: 300; color: var(--cream); line-height: 1.1; margin-bottom: 1.5rem; position: relative; z-index: 1; }
  .consult-left-title em { color: var(--dusty-rose); font-style: italic; }
  .consult-left-body { font-size: 0.88rem; line-height: 1.8; color: rgba(245,240,232,0.5); position: relative; z-index: 1; }
  .consult-right { background: var(--cream); padding: 5rem 4rem; display: flex; flex-direction: column; justify-content: center; gap: 2rem; }
  .consult-right-eyebrow { font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sage); margin-bottom: 0.3rem; }
  .consult-right h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 300; color: var(--warm-brown); margin-bottom: 0.6rem; }
  .consult-right p { font-size: 0.88rem; line-height: 1.75; color: var(--text-muted); }
  .consult-steps { display: flex; flex-direction: column; gap: 1rem; margin-top: 0.5rem; }
  .consult-step { display: flex; align-items: flex-start; gap: 1rem; }
  .consult-step-num { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--dusty-rose); line-height: 1; flex-shrink: 0; margin-top: 0.1rem; }
  .consult-step-text { font-size: 0.85rem; line-height: 1.65; color: var(--text-muted); }
  .consult-step-text strong { color: var(--warm-brown); font-weight: 500; }
  .btn-whatsapp { display: inline-flex; align-items: center; gap: 0.8rem; background: var(--deep-brown); color: var(--cream); padding: 1rem 2rem; text-decoration: none; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; transition: background 0.3s; font-weight: 500; margin-top: 0.5rem; width: fit-content; }
  .btn-whatsapp:hover { background: var(--dusty-rose); color: var(--deep-brown); }
  .consult-note { font-size: 0.75rem; color: var(--text-muted); font-style: italic; line-height: 1.6; border-left: 2px solid rgba(196,160,144,0.3); padding-left: 1rem; }

  /* FOOTER */
  footer { background: var(--deep-brown); border-top: 1px solid rgba(212,168,83,0.15); padding: 3rem 6rem 2rem; display: flex; align-items: center; justify-content: space-between; }
  .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; color: var(--cream); }
  .footer-logo em { color: var(--gold); font-style: italic; }
  .footer-links { display: flex; gap: 2rem; list-style: none; }
  .footer-links a { text-decoration: none; color: rgba(245,240,232,0.4); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
  .footer-links a:hover { color: var(--cream); }
  .footer-copy { font-size: 0.7rem; color: rgba(245,240,232,0.25); }

  /* REVEAL */
  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.75s ease, transform 0.75s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }

  /* MOBILE */
  @media (max-width: 900px) {
    nav { padding: 0.8rem 1.2rem; }
    .nav-links, .nav-book { display: none; }
    .nav-mobile-btn { display: block; }
    .hero { padding: 0 1.5rem 4rem; min-height: 90vh; }
    .hero-ornament { font-size: 55vw; right: -1rem; }
    .understand-section, .approach-inner, .consult-section { grid-template-columns: 1fr; gap: 3rem; }
    .facing-header { grid-template-columns: 1fr; gap: 2rem; }
    .facing-cards, .expect-grid { grid-template-columns: 1fr; }
    .understand-section, .facing-section, .approach-section, .expect-section { padding: 4rem 1.5rem; }
    .note-strip { padding: 2rem 1.5rem; flex-direction: column; gap: 0.8rem; }
    .consult-left, .consult-right { padding: 3rem 1.5rem; }
    footer { flex-direction: column; gap: 1.5rem; padding: 2rem 1.5rem; text-align: center; }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
</head>
